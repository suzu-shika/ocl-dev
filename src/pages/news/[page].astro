---
import NewsArchive from "../../components/news/NewsArchive.astro";
import type { GetStaticPathsOptions } from "astro";
import { getAllNews } from "../../library/microcms";

export const getStaticPaths = async ({ paginate }: GetStaticPathsOptions) => {
  const allNews = await getAllNews({
    fields: ["id", "title", "thumbnail", "thumbnailAlt", "category", "publishedAt"],
    limit: 100,
  });

  const sorted = allNews.contents.sort((a, b) => {
    const dateA = new Date(a.publishedAt).getTime();
    const dateB = new Date(b.publishedAt).getTime();
    return dateB - dateA;
  });

  return paginate(sorted, { pageSize: 6 });
};

const { page } = Astro.props;
const posts = page.data;
---

<NewsArchive
  posts={posts}
  currentPage={page.currentPage}
  lastPage={page.lastPage}
/>
