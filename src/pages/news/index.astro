---
import NewsArchive from "../../components/news/NewsArchive.astro";
import { getAllNews } from "../../library/microcms";

const postsPerPage = 6;

const allPosts = await getAllNews({
  fields: ["id", "title", "thumbnail", "thumbnailAlt", "category", "publishedAt"],
  limit: 100,
});

const sorted = allPosts.contents.sort((a, b) => {
  const dateA = new Date(a.publishedAt).getTime();
  const dateB = new Date(b.publishedAt).getTime();
  return dateB - dateA;
});

const posts = sorted.slice(0, postsPerPage);
const currentPage = 1;
const lastPage = Math.max(1, Math.ceil(sorted.length / postsPerPage));
---

<NewsArchive
  posts={posts}
  currentPage={currentPage}
  lastPage={lastPage}
/>
