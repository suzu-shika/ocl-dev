---
import Layout from "../../layouts/Layout.astro";
import HeadingLv1 from "../../components/common/HeadingLv1.astro";
import BreadCrumb from "../../components/common/Breadcrumb.astro";
import CtaArea from "../../components/common/CtaArea.astro";
---

<Layout
  title="よくある質問 about｜習志野市の幼稚園｜みもみ幼稚園"
  ogType="website"
  description="習志野市のみもみ幼稚園に関する、よくある質問をカテゴリー別にご紹介しています。預かり保育や給食から、子どもの成長に関することまで、安心してご利用いただけるよう丁寧にお答えしています。"
>
  <div class="archive">
    <div class="archive-heading-lv1">
      <HeadingLv1
        headingTitle="お知らせ"
        headingTitleEn="News"
        headingClass="l-container"
      />
    </div><!-- /.archive-heading-lv1 -->

    <main class="archive-main">
      <div class="archive-content">
        <div class="l-container">
          <div class="archive-news-list">
            <a href="/news/single" class="c-news-card">
              <div class="c-news-card-thumbnail">
                <img src="../../../public/assets/images/global/pic-news-thumbnail01@2x.jpg" alt="" loading="lazy" decoding="async" width="318" height="208">
              </div><!-- /.c-news-card-thumbnail -->
              <div class="c-news-card-meta">
                <span class="c-news-card-category">対外活動</span>
                <time datetime="2023-03-01" class="c-news-card-date">2023.03.01</time>
              </div><!-- /.c-news-card-meta -->
              <h3 class="c-news-card-title c-heading-sm">記事タイトル記事タイトル</h3>
            </a>
            <a href="#" class="c-news-card">
              <div class="c-news-card-thumbnail">
                <img src="../../../public/assets/images/global/pic-news-noimage@2x.png" alt="" loading="lazy" decoding="async" width="318" height="208">
              </div><!-- /.c-news-card-thumbnail -->
              <div class="c-news-card-meta">
                <span class="c-news-card-category">お知らせ</span>
                <time datetime="2023-03-01" class="c-news-card-date">2023.03.01</time>
              </div><!-- /.c-news-card-meta -->
              <h3 class="c-news-card-title c-heading-sm">記事タイトル記事タイトル記事タイトル</h3>
            </a>
            <a href="#" class="c-news-card">
              <div class="c-news-card-thumbnail">
                <img src="../../../public/assets/images/global/pic-news-thumbnail01@2x.jpg" alt="" loading="lazy" decoding="async" width="318" height="208">
              </div><!-- /.c-news-card-thumbnail -->
              <div class="c-news-card-meta">
                <span class="c-news-card-category">活動報告</span>
                <time datetime="2023-03-01" class="c-news-card-date">2023.03.01</time>
              </div><!-- /.c-news-card-meta -->
              <h3 class="c-news-card-title c-heading-sm">記事タイトル記事タイトル記事タイトル</h3>
            </a>
            <a href="#" class="c-news-card">
              <div class="c-news-card-thumbnail">
                <img src="../../../public/assets/images/global/pic-news-noimage@2x.png" alt="" loading="lazy" decoding="async" width="318" height="208">
              </div><!-- /.c-news-card-thumbnail -->
              <div class="c-news-card-meta">
                <span class="c-news-card-category">お知らせ</span>
                <time datetime="2023-03-01" class="c-news-card-date">2023.03.01</time>
              </div><!-- /.c-news-card-meta -->
              <h3 class="c-news-card-title c-heading-sm">記事タイトル記事タイトル記事タイトル</h3>
            </a>
            <a href="#" class="c-news-card">
              <div class="c-news-card-thumbnail">
                <img src="../../../public/assets/images/global/pic-news-thumbnail01@2x.jpg" alt="" loading="lazy" decoding="async" width="318" height="208">
              </div><!-- /.c-news-card-thumbnail -->
              <div class="c-news-card-meta">
                <span class="c-news-card-category">活動報告</span>
                <time datetime="2023-03-01" class="c-news-card-date">2023.03.01</time>
              </div><!-- /.c-news-card-meta -->
              <h3 class="c-news-card-title c-heading-sm">記事タイトル記事タイトル記事タイトル</h3>
            </a>
            <a href="#" class="c-news-card">
              <div class="c-news-card-thumbnail">
                <img src="../../../public/assets/images/global/pic-news-noimage@2x.png" alt="" loading="lazy" decoding="async" width="318" height="208">
              </div><!-- /.c-news-card-thumbnail -->
              <div class="c-news-card-meta">
                <span class="c-news-card-category">お知らせ</span>
                <time datetime="2023-03-01" class="c-news-card-date">2023.03.01</time>
              </div><!-- /.c-news-card-meta -->
              <h3 class="c-news-card-title c-heading-sm">記事タイトル記事タイトル記事タイトル</h3>
            </a>
          </div>
          <div class="archive-news-pagination">
            ここにページネイションが入ります。
          </div><!-- /.archive-news-pagination -->
        </div><!-- /.l-container -->
      </div><!-- /.archive-content -->

      <!-- breadcrumb -->
      <BreadCrumb />
    </main>

    <!-- cta-area -->
    <CtaArea />
  </div><!-- /.archive -->
</Layout>

