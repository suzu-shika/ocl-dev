<style lang="scss">
  @use '../../styles/breakpoints' as *;

  .single {
    padding-block-start: 40px;
    margin-block-start: 60px;
  }

  .single-head {
    display: flex;
    flex-direction: column-reverse;
    gap: 16px;
  }

  .single-title {
    text-align: justify;
  }

  .single-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    line-height: 1.5;
  }

  .single-category {
    padding-block: 4px;
    padding-inline: 10px;
    background-color: var(--color-sub-green2);
    color: var(--color-white);
    font-size: 12px;
  }

  .single-date {
    font-size: 14px;
  }

  .single-thumbnail {
    margin-block-start: 40px;

    img {
      height: auto;
      aspect-ratio: 350 / 230;
      object-fit: cover;
    }
  }

  .single-content {
    margin-block-start: 40px;
  }

  .single-btn {
    margin-block-start: 80px;
    text-align: center;
  }

  @include mq() {
    .single {
      padding-block-start: 100px;
      margin-block-start: 80px;
    }

    .single-head {
      // gap: 16px;
    }

    .single-meta {
      gap: 16px;
    }

    .single-category {
      padding-block: 6px;
      padding-inline: 12px;
      font-size: 14px;
    }

    .single-date {
      font-size: 16px;
    }

    .single-thumbnail {
      margin-block-start: 48px;
    }

    .single-content {
      margin-block-start: 64px;
    }

    .single-btn {
      margin-block-start: 100px;
    }
  }
</style>
