---
import Layout from "../layouts/Layout.astro";
import HeadingLv1 from "../components/common/HeadingLv1.astro";
import ActivitiesBackground from "../components/activities/ActivitiesBackground.astro";
import ActivitiesOverview from "../components/activities/ActivitiesOverview.astro";
import ActivitiesActivityReports from "../components/activities/ActivitiesActivityReports.astro";
import ActivitiesVoices from "../components/activities/ActivitiesVoices.astro";

import ActivitiesSponsors from "../components/activities/ActivitiesSponsors.astro";
import ActivitiesCorporatePartners from "../components/activities/ActivitiesCorporatePartners.astro";

import BreadCrumb from "../components/common/Breadcrumb.astro";
import CtaArea from "../components/common/CtaArea.astro";
---

<Layout
  title="企業・自治体と学生が共創するプロジェクト｜活動紹介｜Oita Campus Link"
  ogType="website"
  description="Oita Campus Linkの活動紹介ページです。企業や自治体と学生が共創するプロジェクトやイベントなど、これまでの取り組みをご紹介します。"
>
  <div class="activities">
    <div class="activities-heading-lv1">
      <HeadingLv1
        headingTitle="活動紹介"
        headingTitleEn="Activities"
        headingClass="l-container-s"
      />
    </div><!-- /.activities-heading-lv1 -->

    <main class="activities-main">
      <div class="activities-content">
        <!-- activities-background -->
        <ActivitiesBackground />

        <!-- activities-overview -->
        <ActivitiesOverview />

        <!-- activities-activity-reports -->
        <ActivitiesActivityReports />

        <!-- activities-voices -->
        <ActivitiesVoices />

        <!-- activities-sponsors -->
        <ActivitiesSponsors />

        <!-- activities-corporate-partners -->
        <ActivitiesCorporatePartners />
      </div><!-- /.activities-content -->

      <!-- breadcrumb -->
      <BreadCrumb />
    </main>

    <!-- cta-area -->
    <CtaArea />
  </div><!-- /.activities -->
</Layout>

<style lang="scss">
  @use '../styles/breakpoints' as *;

  .activities {

  }

  .activities-heading-lv1 {

  }

  .activities-main {

  }

  .activities-content {
    margin-block-start: 56px;

    @include mq() {
      margin-block-start: 100px;
    }
  }

</style>
