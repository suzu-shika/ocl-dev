---
import Layout from "../layouts/Layout.astro";
import TopKv from "../components/page-top/TopKv.astro";
import TopAbout from "../components/page-top/TopAbout.astro";
import TopActivities from "../components/page-top/TopActivities.astro";
import TopPartnership from "../components/page-top/TopPartnership.astro";
import TopNews from "../components/page-top/TopNews.astro";
import TopVoices from "../components/page-top/TopVoices.astro";
