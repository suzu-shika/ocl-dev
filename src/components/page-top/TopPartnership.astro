  }

  .top-partnership-item {
    display: flex;
    gap: 8px;

    &::before {
      content: "";
      width: 20px;
      height: 19px;
      margin-block-start: .2em;
      background-image: url(../../../public/assets/images/global/icon-check.svg);
      background-repeat: no-repeat;
      background-size: contain;
      background-position: center center;
      // position: absolute;
      // top: 0;
      // left: 0;
