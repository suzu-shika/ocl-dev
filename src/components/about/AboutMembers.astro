---
import { getMembers } from "../../library/microcms";
import { appendImageFormat } from "../../utils/image";
import { nl2br } from "../../utils/text";

const NO_IMAGE_SRC = "/assets/images/about/pic-about-members-noimage@2x.webp";

const response = await getMembers({
  fields: [
    "id",
    "photo",
    "name",
    "position",
    "affiliation",
    "role",
    "message",
    "sortOrder",
    "publishedAt",
  ],
  limit: 20,
  orders: "sortOrder,-publishedAt",
});

const members = response.contents;
---

<section class="about-members">
  <div class="l-container-s">
    <div class="l-section">
      <div class="about-members-title">
        <div class="c-title">
          <h2 class="c-title-ja">メンバー紹介</h2>
          <span class="c-title-en" aria-hidden="true">Members</span>
        </div>
      </div>

      <div class="l-section-body">
        <div class="about-members-lead">
          <p class="about-members-lead-text">Oita Campus Linkのメンバーは、皆が自分探しの途中です。</p>
          <p class="about-members-lead-text">活動の中枢にいる役員も、さまざまな業務を通しながら「自分は何がしたいのか」という問いの答えを探しています。</p>
          <p class="about-members-lead-text">学年は大学1年生から4年生までと幅広く、学年という壁を越えて、同じ業務に力を合わせて取り組んでいます。</p>
        </div>

        <div class="about-members-title-lv3">
          <h3 class="c-heading-md c-heading-md--green">役員紹介</h3>
        </div>

        <p class="about-members-text">
          Oita Campus Linkの活動を運営・統括している役員をご紹介します。
        </p>

        {
          members.length > 0 ? (
            <ul class="about-members-list">
              {
                members.map((item) => {
                  const hasRealPhoto = Boolean(item.photo?.url);

                  const imageSrc = hasRealPhoto
                    ? appendImageFormat(item.photo.url, "webp")
                    : NO_IMAGE_SRC;

                  const imageAlt = hasRealPhoto
                    ? `${item.name}の顔写真`
                    : "";

                  const displayName = item.position?.trim()
                    ? `${item.name}（${item.position}）`
                    : item.name;

                  return (
                    <li class="about-members-item">
                      <div class="about-members-head">
                        <div class="about-members-image">
                          <img
                            src={imageSrc}
                            alt={imageAlt}
                            loading="lazy"
                            decoding="async"
                            width="180"
                            height="180"
                          />
                        </div>

                        <dl class="about-members-info">
                          <div class="about-members-info-item">
                            <dt class="about-members-term">氏名</dt>
                            <dd class="about-members-description">{displayName}</dd>
                          </div>

                          <div class="about-members-info-item">
                            <dt class="about-members-term">所属</dt>
                            <dd class="about-members-description">{item.affiliation}</dd>
                          </div>

                          <div class="about-members-info-item">
                            <dt class="about-members-term">役割</dt>
                            <dd class="about-members-description">{item.role}</dd>
                          </div>
                        </dl>
                      </div>

                      <div
                        class="about-members-message"
                        set:html={nl2br(item.message)}
                      ></div>
                    </li>
                  );
                })
              }
            </ul>
          ) : (
            <p class="about-members-text">現在、表示できるメンバー情報がありません。</p>
          )
        }
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  .about-members {
    .l-section {
      padding-block-end: 0;
    }
  }

  .about-members-title {
    text-align: center;
  }

  .about-members-lead-text {
    text-align: justify;

    & + & {
      margin-block-start: 16px;
    }
  }

  .about-members-title-lv3 {
    margin-block-start: 80px;
  }

  .about-members-text {
    margin-block-start: 32px;
    text-align: justify;
  }

  .about-members-list {
    display: grid;
    gap: 32px;
    margin-block-start: 32px;
  }

  .about-members-item {
    padding-block: 40px;
    padding-inline: calc(20px / var(--width-sp) * 100vw);
    background-color: var(--color-sub-green1);
  }

  .about-members-head {
    display: grid;
    gap: 24px;
  }

  .about-members-image {
    text-align: center;

    img {
      width: 180px;
      height: auto;
      border-radius: 50%;
      aspect-ratio: 180 / 180;
      object-fit: cover;
    }
  }

  .about-members-info {
    display: grid;
    gap: 4px;
  }

  .about-members-info-item {
    display: flex;
  }

  .about-members-term {
    font-weight: 400;

    &::after {
      content: "：";
    }
  }

  .about-members-message {
    margin-block-start: 24px;
    text-align: justify;
  }

  @include mq() {
    .about-members-text {
      margin-block-start: 40px;
    }

    .about-members-list {
      grid-template-columns: repeat(2, 1fr);
      gap: 40px 24px;
      margin-block-start: 40px;
    }

    .about-members-item {
      padding-inline: 24px;
    }
  }
</style>
