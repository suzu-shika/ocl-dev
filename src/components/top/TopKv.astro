---
import Button from "../common/Button.astro";
---

<div class="top-kv">
  <div class="top-kv-content">
    <div class="l-container">
      <div class="top-kv-logo">
        <img src="../../../public/assets/images/global/icon-logo-mark.svg" alt="" loading="eager" fetchpriority="high" decoding="async" width="380" height="379">
      </div><!-- /.top-kv-logo -->
      <h1 class="top-kv-heading">学生と社会を、<br class="u-no-pc">学生がつなぐ。</h1>
      <p class="top-kv-lead">
        <span>Oita Campus Linkは、<br>学生と企業・行政をつなぎ、<br>学生が社会と共創する機会をつくる。</span>
        <span>学生自身が運営し、<br class="u-no-pc">意思決定するNPO法人です。</span>
      </p>
    </div><!-- /.l-container -->
  </div><!-- /.top-kv-content -->
  <div class="top-kv-cta">
    <Button
      buttonClass="c-btn c-btn--white c-btn--arrow c-btn--mail-icon c-btn--no-border"
      buttonUrl="/contact"
      buttonText="お問い合わせ・ご相談"
      buttonAriaLabel="お問い合わせ・ご相談をする"
    />
  </div><!-- /.top-kv-cta -->
</div><!-- /.top-kv -->

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  .top-kv {
    height: 100vh;
    margin-block-start: 60px;
    // background-color: rgb(0 22 0 / 0.4);
    background-color: var(--color-bg-base);
    // background-image: url(/assets/images/top/bg-kv-sp@2x.webp);
    background-repeat: no-repeat;
    background-size: cover;
    background-position: center center;
    // color: var(--color-white);
    color: var(--color-base);
    font-family: var(--font-family-serif);
    font-weight: 700;
    position: relative;
  }

  .top-kv-content {
    width: 100%;
    position: absolute;
    top: 50%;
    left: 0;
    transform: translateY(-50%);

    .l-container {
      position: relative;
    }
  }

  .top-kv-heading {
    font-size: 40px;
  }

  .top-kv-lead {
    display: grid;
    gap: 1em;
    margin-block-start: 1.5em;
    font-size: 16px;
  }

  .top-kv-logo {
    width: 150px;
    margin-block-end: 40px;
    margin-inline-start: auto;
    // position: absolute;
    // top: 0;
    opacity: .9;
  }

  .top-kv-cta {
    width: 100%;
    padding: calc(1em - 1px) 0;
    background-color: #003300;
    text-align: center;
    position: absolute;
    bottom: 0;
    left: 0;
  }
</style>
