---
import Button from "../common/Button.astro";

import { getNews } from "../../library/microcms";
import { appendImageFormat } from "../../utils/image";
import { formatYmd } from "../../utils/date";
import { truncateText } from "../../utils/text";

const baseNoImageSrc = "/assets/images/global/pic-news-noimage@2x.webp";

// 最新3件取得
const response = await getNews({
  fields: [
    "id",
    "title",
    "thumbnail",
    "thumbnailAlt",
    "category",
    "publishedAt",
  ],
  limit: 3,
  orders: "-publishedAt",
});

const posts = response.contents;
---

<section class="top-news">
  <div class="l-container">
    <div class="l-section">
      <div class="top-news-title">
        <div class="c-title">
          <h2 class="c-title-ja">お知らせ</h2>
          <span class="c-title-en" aria-hidden="true">News</span>
        </div>
      </div>

      <div class="l-section-body">
        <div class="top-news-list">
          {posts.length > 0 ? (
              posts.map((item) => {
                const thumbSrc = item.thumbnail?.url
                  ? `${item.thumbnail.url}${item.thumbnail.url.includes("?") ? "&" : "?"}fm=webp`
                  : baseNoImageSrc;

                const altText =
                  (item.thumbnailAlt && item.thumbnailAlt.trim()) ||
                  "お知らせのサムネイル画像";

                const displayDate = formatYmd(item.publishedAt);

                return (
                  <a
                    href={`/news/${item.id}`}
                    class="c-news-card"
                    aria-label={`お知らせ: ${item.title}`}
                  >
                    <div class="c-news-card-thumbnail">
                      <img
                        src={thumbSrc}
                        alt={altText}
                        loading="lazy"
                        decoding="async"
                        width="318"
                        height="208"
                      />
                    </div>

                    <div class="c-news-card-meta">
                      <span class="c-news-card-category">{item.category}</span>
                      <time datetime={item.publishedAt} class="c-news-card-date">
                        {displayDate}
                      </time>
                    </div>

                    <h3 class="c-news-card-title c-heading-sm">
                      {truncateText(item.title, 60)}
                    </h3>
                  </a>
                );
              })
            ) : (
              <p class="archive-news-empty">現在、表示できる記事がありません。</p>
            )}
        </div>

        <div class="top-news-btn">
          <Button
            buttonClass="c-btn c-btn--arrow"
            buttonUrl="/news"
            buttonText="お知らせ一覧"
            buttonAriaLabel="お知らせ一覧を見る"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  .top-news-list {
    display: grid;
    gap: 36px;
  }

  .top-news-btn {
    margin-block-start: 56px;
    text-align: center;
  }

  @include mq() {
    .top-news-list {
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }

    .top-news-btn {
      margin-block-start: 80px;
    }
  }
</style>
