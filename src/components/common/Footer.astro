---
import Button from "./Button.astro";
const { logo, logoAlt } = Astro.props;
---

<!-- footer -->
<footer class="footer">
  <div class="l-container">
    <div class="footer-logo">
      <a href="/">
        <img
          src={logo}
          alt={logoAlt}
          loading="lazy"
          decoding="async"
          width="200"
          height="41"
        />
      </a>
    </div><!-- /.footer-logo -->

    <nav class="footer-nav" aria-label="フッターナビゲーション">
      <ul class="footer-nav-list">
        <li class="footer-nav-item">
          <a href="/">ホーム</a>
        </li>
        <li class="footer-nav-item">
          <a href="/about">Oita Campus Linkについて</a>
        </li>
        <li class="footer-nav-item">
          <a href="/activities">活動紹介</a>
        </li>
        <li class="footer-nav-item">
          <a href="/news">お知らせ</a>
        </li>
        <li class="footer-nav-item">
          <a href="/faq">よくあるご質問</a>
        </li>
        <li class="footer-nav-item">
          <a href="/contact">お問い合わせ</a>
        </li>
      </ul>
    </nav>

    <div class="footer-cta">
      <Button
        buttonClass="c-btn c-btn--arrow c-btn--white c-btn--mail-icon"
        buttonUrl="/contact"
        buttonText="お問い合わせ・ご相談"
        buttonAriaLabel="お問い合わせ・ご相談をする"
      />
    </div><!-- /.footer-cta -->

    <div class="footer-links">
      <ul class="footer-sns-list">
        <li class="footer-sns-item">
          <a href="https://www.instagram.com/oitagakusei_tokyo/" target="_blank" rel="noopener noreferrer">
            <img src="/assets/images/global/icon-instagram.svg" alt="Instagram" loading="lazy" decoding="async" width="26" height="26">
          </a>
        </li>
        <li class="footer-sns-item">
          <a href="https://www.instagram.com/oitagakusei_tokyo/" target="_blank" rel="noopener noreferrer">
            <img src="/assets/images/global/icon-line.svg" alt="LINE" loading="lazy" decoding="async" width="26" height="26">
          </a>
        </li>
      </ul>
      <div class="footer-privacy-policy">
        <a href="/privacy-policy">プライバシーポリシー</a>
      </div><!-- /.footer-privacy-policy -->
    </div><!-- /.footer-links -->

    <div class="footer-copyright">
      <small aria-label="著作権 2026 Oita Campus Link">
        &copy;2026 Oita Campus Link.
      </small>
    </div><!-- /.footer-copyright -->
  </div><!-- /.l-container -->

  <!-- トップへ戻るボタン -->
  <a href="#body" class="footer-page-top" aria-label="ページトップへ戻る">
    <img
      src="/assets/images/global/icon-arrow-up.svg"
      alt=""
      loading="lazy"
      decoding="async"
      width="6"
      height="16"
    />
  </a><!-- /.footer-page-top -->
</footer>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const pageTop = document.querySelector(".footer-page-top");
    const footer = document.querySelector(".footer");

    if (!pageTop || !footer) return;

    // 初期状態
    pageTop.style.opacity = "0";
    pageTop.style.pointerEvents = "none";

    let footerVisible = false;

    // フッター検知
    const observer = new IntersectionObserver(
      (entries) => {
        footerVisible = entries[0].isIntersecting;
        toggleButton();
      },
      {
        root: null,
        threshold: 0
      }
    );

    observer.observe(footer);

    // スクロール監視
    window.addEventListener("scroll", toggleButton);

    // ページトップへ戻る
    pageTop.addEventListener("click", (e) => {
      e.preventDefault();
      window.scrollTo({
        top: 0,
        behavior: "smooth",
      });
    });

    function toggleButton() {
      const scrollY = window.scrollY;

      if (scrollY > 200 && !footerVisible) {
        pageTop.style.opacity = "1";
        pageTop.style.pointerEvents = "auto";
      } else {
        pageTop.style.opacity = "0";
        pageTop.style.pointerEvents = "none";
      }
    }
  });
</script>

<style lang="scss">
  @use "../../styles/breakpoints" as *;

  .footer {
    padding-block: 80px 40px;
    background-color: var(--color-green);
    color: var(--color-white);
    font-family: var(--font-family-serif);
    font-weight: 700;
  }

  .footer-logo {
    img {
      max-width: 200px;
    }
  }

  .footer-nav {
    margin-block-start: 32px;
  }

  .footer-nav-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .footer-nav-item {
    a {
      display: block;
      padding-block-end: 10px;
      border-bottom: 1px solid;
    }
  }

  .footer-cta {
    margin-block-start: 64px;
    text-align: center;
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    margin-block-start: 64px;
  }

  .footer-sns-list {
    display: flex;
    justify-content: center;
    gap: 20px;
  }

  .footer-sns-item {
    img {
      width: 24px;
    }
  }

  .footer-privacy-policy {
    a {
      font-size: 12px;
      text-decoration: underline;
    }
  }

  .footer-copyright {
    margin-block-start: 24px;
    text-align: center;

    small {
      font-size: 12px;
    }
  }

  .footer-page-top {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--color-green);
    background-color: var(--color-green);
    opacity: 0;
    pointer-events: none;
    transition: opacity .3s;
    position: fixed;
    right: 20px;
    bottom: 10px;

    img {
      width: 6px;
      filter: invert(100%) sepia(71%) saturate(2%) hue-rotate(326deg) brightness(113%) contrast(101%);
    }
  }

  @include mq() {
    .footer {
      .l-container {
        // width: fit-content;
      }
    }

    .footer-logo {
      img {
        max-width: 240px;
      }
    }

    .footer-nav {
      margin-block-start: 64px;
    }

    .footer-nav-list {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
      gap: 20px 49px;
      // gap: min(49px, calc(49 / 850 * 100vw));
    }

    .footer-nav-item {
      font-size: min(16px, calc(16 / 850 * 100vw));
      font-size: 16px;

      a {
        padding-block: 8px;
        border: none;
      }

      &:not(:last-child) {
        position: relative;

        &::after {
          content: "";
          width: 1px;
          height: 1em;
          background-color: var(--color-white);
          position: absolute;
          top: 50%;
          right: max(-24px, calc(-24 / 850 * 100vw));
          transform: translateY(-50%);
        }
      }
    }

    .footer-links {
      flex-direction: row;
      justify-content: center;
    }

    .footer-sns-list {
      gap: 24px;
    }

    .footer-sns-item {
      img {
        width: 24px;
      }
    }

    .footer-privacy-policy {
      a {
        font-size: 12px;
        text-decoration: underline;
      }
    }

    .footer-copyright {
      margin-block-start: 24px;
      text-align: center;

      small {
        font-size: 12px;
      }
    }

    .footer-page-top {
      width: 48px;
      height: 48px;
      right: 24px;
      bottom: 24px;

      img {
        width: 8px;
      }
    }
  }

  @media (any-hover: hover) {
    a {
      transition: opacity .3s ease;
      &:hover  {
        opacity: .75;
      }
    }

    .footer-page-top {
      transition: background-color .3s;

      img {
        transition: filter .3s;
      }
      &:hover {
        background-color: var(--color-white);

        img {
          filter: invert(16%) sepia(32%) saturate(2179%) hue-rotate(82deg) brightness(90%) contrast(108%);
        }
      }
    }
  }
</style>
