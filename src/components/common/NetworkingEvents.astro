---
import Button from "./Button.astro";
import { getNetworkingEvents } from "../../library/microcms";
import { appendImageFormat } from "../../utils/image";
import { formatJapaneseDate } from "../../utils/date";
import { nl2br } from "../../utils/text";

const NO_IMAGE_SRC = "/assets/images/global/pic-news-noimage@2x.webp";

const response = await getNetworkingEvents({
  fields: [
    "id",
    "eventDate",
    "titleText",
    "thumbnail",
    "thumbnailAlt",
    "text",
    "newsId",
    "sortOrder",
  ],
  limit: 6,
  orders: "sortOrder,-eventDate",
});

const events = response.contents;
---

<div
  id="slider2"
  class="splide c-activity-reports-splide"
  role="group"
  aria-labelledby="networking-events-carousel-heading"
>
  <div class="splide__track c-activity-reports-splide-track">
    <ul class="splide__list c-activity-reports-list">
      {
        events.length > 0 ? (
          events.map((item) => {
            const thumbnailSrc = item.thumbnail?.url
              ? appendImageFormat(item.thumbnail.url, "webp")
              : NO_IMAGE_SRC;

            const thumbnailAlt =
              (item.thumbnailAlt && item.thumbnailAlt.trim()) ||
              "交流会のサムネイル画像";

            const detailUrl = item.newsId
              ? `/news/${item.newsId}`
              : "/news";

            return (
              <li class="splide__slide c-activity-reports-item">
                <h4 class="c-activity-reports-title">
                  <span class="c-activity-reports-title-date">
                    {formatJapaneseDate(item.eventDate)}
                  </span>
                  <span class="c-activity-reports-title-text">
                    {item.titleText}
                  </span>
                </h4>

                <div class="c-activity-reports-thumbnail">
                  <img
                    src={thumbnailSrc}
                    alt={thumbnailAlt}
                    loading="lazy"
                    decoding="async"
                    width="310"
                    height="200"
                  />
                </div>

                <div
                  class="c-activity-reports-text"
                  set:html={nl2br(item.text)}
                ></div>

                <div class="c-activity-reports-btn">
                  <Button
                    buttonClass="c-btn"
                    buttonUrl={detailUrl}
                    buttonText="詳しく見る"
                    buttonAriaLabel={`${item.titleText}の詳細を見る`}
                  />
                </div>
              </li>
            );
          })
        ) : (
          <li class="splide__slide c-activity-reports-item">
            <p class="c-activity-reports-text">
              現在、表示できる交流会情報がありません。
            </p>
          </li>
        )
      }
    </ul>
  </div>
</div>

<script>
  const splide = new Splide("#slider2", {
    perPage: 2,
    focus: 0,
    omitEnd: true,
    gap: "24px",
    breakpoints: {
      767: {
        perPage: 1,
        gap: "24px",
      },
    },
    classes: {
      pagination: "splide__pagination c-activity-reports-pagination",
      page: "splide__pagination__page c-activity-reports-page",
    },
    arrows: false,
  });

  splide.mount();

</script>

<style is:global lang="scss">
  @use '../../styles/breakpoints' as *;

  .c-activity-reports-item {
    display: flex;
    flex-direction: column;
    gap: 32px;
    padding-block: 40px;
    padding-inline: calc(20px / var(--width-sp) * 100vw);
    background-color: var(--color-white);

    @include mq() {
      padding-inline: 24px;
    }
  }

  .c-activity-reports-title {
    display: grid;
    font-family: var(--font-family-serif);
    font-size: 20px;
    font-weight: 700;
    line-height: 1.5;
    text-align: justify;
  }

  .c-activity-reports-title-date {
    font-size: 16px;
  }

  .c-activity-reports-thumbnail {
    img {
      height: auto;
      aspect-ratio: 310 / 200;
      object-fit: cover;
    }
  }

  .c-activity-reports-text {
    text-align: justify;
  }

  .c-activity-reports-btn {
    margin-block-start: auto;
    text-align: center;
  }

  // pagination
  .c-activity-reports-pagination {
    bottom: calc(-16px + -32px);
  }

  .c-activity-reports-page {
    width: 16px;
    height: 16px;
    margin-block: 0;
    margin-inline: 8px;
    background-color: var(--color-white);
    opacity: 1;

    &.is-active {
      background-color: var(--color-green);
      transform: none;
    }
  }
</style>
