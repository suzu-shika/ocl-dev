---
import Button from "./Button.astro";
import { getCoCreation } from "../../library/microcms";
import { appendImageFormat } from "../../utils/image";
import { formatJapaneseDate } from "../../utils/date";
import { nl2br } from "../../utils/text";

const NO_IMAGE_SRC = "/assets/images/global/pic-news-noimage@2x.webp";

const response = await getCoCreation({
  fields: [
    "id",
    "publishedAt",
    "titleText",
    "thumbnail",
    "thumbnailAlt",
    "text",
    "newsId",
    "sortOrder",
  ],
  limit: 6,
  orders: "sortOrder,-publishedAt",
});

const events = response.contents;
---

<div
  id="slider3"
  class="splide c-activity-reports-splide"
  role="group"
  aria-labelledby="networking-events-carousel-heading"
>
  <div class="splide__track c-activity-reports-splide-track">
    <ul class="splide__list c-activity-reports-list">
      {
        events.length > 0 ? (
          events.map((item) => {
            const thumbnailSrc = item.thumbnail?.url
              ? appendImageFormat(item.thumbnail.url, "webp")
              : NO_IMAGE_SRC;

            const thumbnailAlt =
              (item.thumbnailAlt && item.thumbnailAlt.trim()) ||
              "交流会のサムネイル画像";

                          const detailUrl = item.newsId
              ? `/news/${item.newsId}`
              : "/news";

            return (
              <li class="splide__slide c-activity-reports-item">
                <h4 class="c-activity-reports-title">
                  <span class="c-activity-reports-title-text">
                    {item.titleText}
                  </span>
                </h4>

                <div class="c-activity-reports-thumbnail">
                  <img
                    src={thumbnailSrc}
                    alt={thumbnailAlt}
                    loading="lazy"
                    decoding="async"
                    width="310"
                    height="200"
                  />
                </div>

                <div class="c-activity-reports-text" set:html={nl2br(item.text)}></div>

                <div class="c-activity-reports-btn">
                  <Button
                    buttonClass="c-btn"
                    buttonUrl={detailUrl}
                    buttonText="詳しく見る"
                    buttonAriaLabel={`${item.titleText}の詳細を見る`}
                  />
                </div>
              </li>
            );
          })
        ) : (
          <li class="splide__slide c-activity-reports-item">
            <p class="c-activity-reports-text">
              現在、表示できる交流会情報がありません。
            </p>
          </li>
        )
      }
    </ul>
  </div>
</div>

<script>
  var splide = new Splide( '#slider3', {
    perPage: 2,
    focus: 0,
    omitEnd: true,
    gap: '24px',
    breakpoints: {
      767: {
        perPage: 1,
        gap : '24px',
      },
    },
    classes: {
      pagination: "splide__pagination c-activity-reports-pagination",
      page: "splide__pagination__page c-activity-reports-page",
    },
    arrows: false,
  } );

  splide.mount();
</script>

<style is:global lang="scss">
  @use '../../styles/breakpoints' as *;

</style>
