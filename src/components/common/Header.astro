---
import Button from "./Button.astro";

const { logo, logoAlt } = Astro.props;
const isTopPage = Astro.url.pathname === "/";
---

<!-- header -->
<header class="header" id="site-header">
  <div class="header-container l-container">
    <p class="header-logo">
      <a href="/">
        <img
          src={logo}
          alt={logoAlt}
          loading="eager"
          decoding="async"
          width="200"
          height="41"
          fetchpriority="low"
        />
      </a>
    </p>
    <button class="header-hamburger" type="button">
      <span class="header-hamburger-icon"></span>
      <span class="header-hamburger-icon"></span>
      <span class="header-hamburger-icon"></span>
      <span class="u-sr-only">メニュー</span>
    </button>
    <div class="header-link">
      <nav class="header-nav" aria-label="サイトナビゲーション">
        <ul class="header-nav-list">
          <li class="header-nav-item header-nav-item--top">
            <a href="/">トップ</a>
          </li>
          <li class="header-nav-item">
            <a href="/about">Oita Campus Linkについて</a>
          </li>
          <li class="header-nav-item">
            <a href="/activities">活動紹介</a>
          </li>
          <li class="header-nav-item">
            <a href="/news">お知らせ</a>
          </li>
          <li class="header-nav-item header-nav-item--pc-contact">
            <a href="/contact">お問い合わせ</a>
          </li>
          <li class="header-nav-item header-nav-item--sp-contact">
            <Button
              buttonClass="c-btn c-btn--arrow c-btn--white c-btn--mail-icon"
              buttonUrl="/contact"
              buttonText="お問い合わせ・ご相談"
              buttonAriaLabel="お問い合わせ・ご相談をする"
            />
          </li>
        </ul>
      </nav>
      <ul class="header-sns">
        <li class="header-sns-item">
          <a href="https://www.instagram.com/oitagakusei_tokyo/" target="_blank" rel="noopener noreferrer">
            <img src="../../../public/assets/images/global/icon-instagram.svg" alt="Instagram" loading="lazy" decoding="async" width="26" height="26">
          </a>
        </li>
        <li class="header-sns-item">
          <a href="https://www.instagram.com/oitagakusei_tokyo/" target="_blank" rel="noopener noreferrer">
            <img src="../../../public/assets/images/global/icon-line.svg" alt="LINE" loading="lazy" decoding="async" width="26" height="26">
          </a>
        </li>
      </ul>
    </div><!-- /.header-link -->
  </div><!-- /.header-container.l-container -->
</header>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const hamburger = document.querySelector(".header-hamburger");
    const headerLinks = document.querySelector(".header-link");
    const navLinks = document.querySelectorAll(".header-link a");
    const body = document.body;
    const navButtons = document.querySelectorAll(".header-nav-btn");
    let scrollY = 0; // スクロール位置の保存用

    hamburger.addEventListener("click", function () {
      const isActive = this.classList.toggle("active");
      headerLinks.classList.toggle("active");

      if (isActive) {
        scrollY = window.scrollY;
        body.style.position = "fixed";
        body.style.top = `-${scrollY}px`;
        body.style.left = "0";
        body.style.right = "0";
        body.classList.add("no-scroll");
      } else {
        body.style.position = "";
        body.style.top = "";
        body.style.left = "";
        body.style.right = "";
        body.classList.remove("no-scroll");
        window.scrollTo(0, scrollY);
      }
    });

    // ナビゲーションリンククリック時にメニューを閉じる
    navLinks.forEach(function (link) {
      link.addEventListener("click", function () {
        hamburger.classList.remove("active");
        headerLinks.classList.remove("active");
        body.style.position = "";
        body.style.top = "";
        body.style.left = "";
        body.style.right = "";
        body.classList.remove("no-scroll");
        window.scrollTo(0, scrollY);
      });
    });

    // navボタンクリック時のサブメニュー開閉処理
    navButtons.forEach((button) => {
      button.addEventListener("click", function () {
        const expanded = this.getAttribute("aria-expanded") === "true";
        const hiddenList = this.nextElementSibling;

        navButtons.forEach((btn) => {
          btn.setAttribute("aria-expanded", "false");
          btn.classList.remove("is-open");
          if (
            btn.nextElementSibling &&
            btn.nextElementSibling.classList.contains("header-hidden-list")
          ) {
            const list = btn.nextElementSibling;
            list.classList.remove("is-open");
            list.style.height = "0"; // 高さをリセット
          }
        });

        if (!expanded) {
          this.setAttribute("aria-expanded", "true");
          this.classList.add("is-open");
          if (
            hiddenList &&
            hiddenList.classList.contains("header-hidden-list")
          ) {
            hiddenList.classList.add("is-open");
            const scrollHeight = hiddenList.scrollHeight; // 中身に合わせた高さを取得
            hiddenList.style.height = scrollHeight + "px";
          }
        }
      });
    });

    // スクロール時に.subメニューを閉じる
    window.addEventListener("scroll", function () {
      navButtons.forEach((btn) => {
        btn.setAttribute("aria-expanded", "false");
        btn.classList.remove("is-open");
        const hiddenList = btn.nextElementSibling;
        if (hiddenList && hiddenList.classList.contains("header-hidden-list")) {
          hiddenList.classList.remove("is-open");
          hiddenList.style.height = "0";
        }
      });
    });
  });
</script>

<style lang="scss">
  @use "../../styles/breakpoints" as *;

  // header
  .header {
    display: grid;
    align-items: center;
    width: 100%;
    height: 80px;
    background-color: rgb(0 22 0 / .4);
    color: var(--color-white);
    font-family: var(--font-family-serif);
    font-size: 16px;
    font-weight: 700;
    position: fixed;
    top: 0;
    left: 0;
    z-index: 20;
  }

  .header-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .header-logo {
    width: 100%;
    max-width: 240px;

    a {
      display: block;
    }
  }

  .header-nav-list {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .header-nav-item {
    position: relative;

    a {
      display: block;
      padding-block: 8px;
    }

    &--top {
      display: none;
    }

    &--pc-contact {
      a {
        display: flex;
        align-items: center;
        gap: 8px;
        padding-inline: 16px;
        border-radius: 50px;
        background-color: var(--color-white);
        color: var(--color-green);

        &::before {
          content: "";
          width: 21px;
          height: 16px;
          background-image: url(../../../public/assets/images/global/icon-mail-green.svg);
          background-repeat: no-repeat;
          background-size: contain;
          background-position: center center;
        }
      }
    }

    &--sp-contact {
      display: none;
    }
  }

  .header-sns {
    display: none;
  }

  @media screen and (max-width: 1023px) {
    .header {
      font-size: 15px;
    }

    .header-container {
      width: 100%;
      padding-inline: calc(20px / var(--width-sp) * 100vw);
      position: relative;
    }

    .header-logo {
      position: relative;
      z-index: 30;
    }

    // hamburger icon
    .header-hamburger {
      width: 30px;
      height: 60px;
      margin: auto 0;
      position: absolute;
      top: 0;
      bottom: 0;
      right: calc(20px / var(--width-sp) * 100vw);
      z-index: 30;
    }

    .header-hamburger-icon {
      display: inline-block;
      width: inherit;
      height: 1px;
      background-color: var(--color-white);
      position: absolute;
      left: 0;
      transition: all 0.3s ease;

      &:nth-of-type(1) {
        top: 24px;
      }

      &:nth-of-type(2) {
        display: none;
        top: 30px;
      }

      &:nth-of-type(3) {
        top: 36px;
      }
    }

    // animation
    .header-hamburger span:nth-of-type(1) {
      animation: btn07-bar01 0.6s forwards;
    }
    @keyframes btn07-bar01 {
      0% {
        transform: translateY(6px) rotate(30deg);
      }
      50% {
        transform: translateY(6px) rotate(0);
      }
      100% {
        transform: translateY(0) rotate(0);
      }
    }
    .header-hamburger span:nth-of-type(2) {
      transition: all 0.25s 0.25s;
      opacity: 1;
    }
    .header-hamburger span:nth-of-type(3) {
      animation: btn07-bar03 0.6s forwards;
    }
    @keyframes btn07-bar03 {
      0% {
        transform: translateY(-6px) rotate(-30deg);
      }
      50% {
        transform: translateY(-6px) rotate(0);
      }
      100% {
        transform: translateY(0) rotate(0);
      }
    }
    .header-hamburger.active span:nth-of-type(1) {
      animation: active-btn07-bar01 0.6s forwards;
    }
    @keyframes active-btn07-bar01 {
      0% {
        transform: translateY(0) rotate(0);
      }
      50% {
        transform: translateY(6px) rotate(0);
      }
      100% {
        transform: translateY(6px) rotate(30deg);
      }
    }
    .header-hamburger.active span:nth-of-type(2) {
      opacity: 0;
    }
    .header-hamburger.active span:nth-of-type(3) {
      animation: active-btn07-bar03 0.6s forwards;
    }
    @keyframes active-btn07-bar03 {
      0% {
        transform: translateY(0) rotate(0);
      }
      50% {
        transform: translateY(-6px) rotate(0);
      }
      100% {
        transform: translateY(-6px) rotate(-30deg);
      }
    }

    // hamburger menu
    .header-link {
      width: 70%;
      height: 100vh;
      padding-block-start: 130px;
      padding-inline: calc(20px / var(--width-sp) * 100vw);
      background-color: var(--color-green);
      position: fixed;
      top: 0;
      right: -70%;
      z-index: 20;
      overflow: auto;
      transition: all 0.6s ease;

      &.active {
        right: 0;
      }
    }

    .header-nav {
      width: 100%;
    }
    .header-nav-list {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
    }

    .header-nav-item {
      width: 100%;
      border-bottom: 1px solid;

      a {
        display: block;
        padding-block: 10px;
      }

      &--top {
        display: block;
      }

      &--pc-contact {
        display: none;
      }

      &--sp-contact {
        display: block;
        margin-block-start: 40px;
        border: none;
        text-align: center;
      }
    }

    .header-sns {
      display: flex;
      justify-content: center;
      gap: 20px;
      margin-block-start: 64px;
    }

    .header-sns-item {
      img {
        width: 24px;
      }
    }
  }

  @media screen and (max-width: 767px) {
    .header {
      height: 60px;
    }

    .header-logo {
      max-width: 200px;
    }

    // hamburger menu
    .header-link {
      width: 100%;
      right: -100%;
    }
  }

  // hover action
  @media (any-hover: hover) {
    .header-nav-item {
      a {
        transition: opacity 0.3s ease;

        &:hover {
          opacity: .8;
        }
      }
    }
  }
</style>
