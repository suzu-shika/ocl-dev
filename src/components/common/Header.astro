    .header-hamburger-icon {
      display: inline-block;
      width: 23px;
      height: 2px;
      background-color: var(--color-white);
      position: absolute;
      left: 0;
      transition: all 0.3s ease;

      &:nth-of-type(1) {
        top: 16px;
      }

