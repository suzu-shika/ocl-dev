---
import "../styles/style.scss";
import Header from "../components/common/Header.astro";
import Footer from "../components/common/Footer.astro";

const logo = "/assets/images/global/logo.png";
const logoAlt = "Oita Campus Link";
const {
  title = "産学連携とは違う。学生が社会と共創する機会をつくるNPO｜Oita Campus Link",
  ogType = "website",
  ogTitle = title,
  description = "Oita Campus Linkは、学生自身が運営し意思決定するNPO法人です。従来の産学連携とは異なる形で学生と企業・自治体をつなぎ、対等な共創が生まれる機会をつくることを目的としています。",
  ogDescription = description,
  ogImage = "https://ocl.or.jp/ogp.png",
  noIndex = false,
  jsonLd = ""
} = Astro.props;
---

<!DOCTYPE html>
<html lang="ja" prefix="og: https://ogp.me/ns#">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>

    { noIndex && <meta name="robots" content="noindex, nofollow" /> }
    <meta name="robots" content="noindex, nofollow" />

    <!-- favicon -->
    <link rel="shortcut icon" href="/favicon.ico">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" href="/android-chrome-256x256.png">

    <!-- ogp -->
    <meta property="og:site_name" content="NPO法人 Oita Campus Link">
    <meta property="og:url" content={`https://ocl.or.jp${Astro.url.pathname}`} />
    <meta property="og:type" content={ogType}>
    <meta property="og:title" content={ogTitle}>
    <meta property="og:description" content={ogDescription}>
    <meta property="og:image" content={ogImage}>
    <meta property="og:locale" content="ja_JP">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:description" content={ogDescription}>
    <meta name="twitter:image:src" content={ogImage}>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Italiana&family=Noto+Serif+JP:wght@700&display=swap"
    >

    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Italiana&family=Noto+Serif+JP:wght@700&display=swap"
    >

    <!-- Spride -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@splidejs/splide@4.1.4/dist/css/splide.min.css">
    <script src="https://cdn.jsdelivr.net/npm/@splidejs/splide@4.1.4/dist/js/splide.min.js" defer></script>

    <!-- destyle.css（preload+onload） -->
    <link rel="preload" href="https://cdn.jsdelivr.net/npm/destyle.css@4.0.0/destyle.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/destyle.css@4.0.0/destyle.min.css"></noscript>

    <!-- ヒーロー画像のpreload -->
    <!-- <link rel="preload" as="image" href="/assets/images/top/bg-kv-sp@2x.webp" fetchpriority="high"> -->

    <!-- 構造化データ -->
    {jsonLd && (
      <script type="application/ld+json" set:html={jsonLd}></script>
    )}
  </head>

  <body id="body">
    <Header
      logo={logo}
      logoAlt={logoAlt}
    />

    <slot />

    <Footer
      logo={logo}
      logoAlt={logoAlt}
    />
    <script src="/assets/js/main.js" defer></script>
  </body>
</html>
